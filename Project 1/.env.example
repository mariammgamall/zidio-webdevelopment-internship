# ==========================================
# IntellMeet Server Config
# ==========================================
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Databases
MONGO_URI=mongodb://localhost:27017/intellmeet
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Sentry
SENTRY_DSN=  

# Cloudinary Storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI Credentials (Optional; mock fallback enabled)
OPENAI_API_KEY=
HF_API_KEY=
HF_SUMMARY_MODEL=facebook/bart-large-cnn

# OAuth2 Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# CORS Configuration
CLIENT_ORIGIN=http://localhost:5173

# ==========================================
# IntellMeet Client Config (React)
# ==========================================
VITE_API_URL=/api
VITE_SOCKET_URL=/
VITE_SENTRY_DSN=
